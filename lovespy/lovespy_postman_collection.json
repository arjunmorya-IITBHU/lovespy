					"name": "Create Order (checkout log)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"delivery_name\": \"Priya Sharma\",\n    \"delivery_phone\": \"9876543210\",\n    \"delivery_line1\": \"F-12, Green Park Extension\",\n    \"delivery_city\": \"New Delhi\",\n    \"delivery_state\": \"Delhi\",\n    \"delivery_pincode\": \"110016\",\n    \"delivery_type\": \"standard\",\n    \"delivery_date\": \"2026-06-03\",\n    \"delivery_slot\": \"9:00 AM - 12:00 PM\",\n    \"subtotal\": 2499,\n    \"shipping_charge\": 0,\n    \"total_amount\": 2499,\n    \"coupon_code\": \"LOVESPY10\"\n}"
						},
