	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Send OTP Verification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"9876543210\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/otp/send",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"otp",
								"send"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify OTP & Issue JWT Token",
