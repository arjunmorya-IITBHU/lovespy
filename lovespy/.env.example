# ==========================================
# Lovespy - Environment Variables Configuration
# Copy this file to '.env.local' or '.env' and populate values
# ==========================================

# Next.js Server Environment
NODE_ENV=development
PORT=3000

# Database Configuration (PostgreSQL/Supabase)
DATABASE_URL="postgresql://username:password@localhost:5432/lovespy_db?schema=public"

# MongoDB Database Alternative (if applicable)
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/lovespy?retryWrites=true&w=majority"

# Authentication Secrets (JWT)
JWT_ACCESS_SECRET="your-jwt-access-token-secret-key-32-chars-long"
JWT_REFRESH_SECRET="your-jwt-refresh-token-secret-key-32-chars-long"

# Auth Providers - Google OAuth
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# AWS S3 Storage (For Polaroid photos and Voice recordings uploads)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_NAME="lovespy-gifting-media-bucket"

# SMS OTP Provider (Twilio or MSG91)
SMS_PROVIDER_API_KEY="your-sms-provider-api-key"
SMS_SENDER_ID="LOVESP"

# Payment Gateways - Razorpay (India checkout)
RAZORPAY_KEY_ID="rzp_test_yourKeyId"
RAZORPAY_KEY_SECRET="yourRazorpayKeySecret"

# Payment Gateways - PayPal (International checkout)
PAYPAL_CLIENT_ID="your-paypal-sandbox-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-sandbox-client-secret"
